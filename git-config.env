# Git identity — set your name and email before running setup.ps1
GIT_NAME=Your Name
GIT_EMAIL=you@example.com

# Python version to install (default: 3.13)
PYTHON_VERSION=3.13

# Set to true to install VS Code + Python extensions
INSTALL_VSCODE=false

# Set to true to install AWS CLI via official MSI
INSTALL_AWS_CLI=false
